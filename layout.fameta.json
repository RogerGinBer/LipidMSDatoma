{
  "parameters": [
    {
      "label": "Parameters",
      "parameters": [
        {
          "key": "resolution",
          "label": "Mass resolution",
          "type": "InputNumber",
          "model": 140000,
          "bind": {
            "min" : 0,
            "max" : 1000000
          }
        },
               {
          "key": "correct13C",
          "label": "Correct for natural 13C abundance",
          "type": "InputSwitch",
          "model": true
        },
        {
          "key": "purity13C",
          "label": "13C Tracer purity",
          "type": "InputNumber",
          "model": 0.99,
          "bind": {
            "step" : 0.001,
            "min" : 0,
            "max" : 1
          },
          "enable": "parameters[key = \"correct13C\"].model"
        },
        {
          "key": "runelongation",
          "label": "Run elongation pathway analysis",
          "type": "InputSwitch",
          "model": true
        },
        {
          "key": "maxiterelo",
          "label": "Maximum iterations for elongation calculation",
          "type": "InputNumber",
          "model": 10000,
          "bind": {
            "min" : 1000,
            "max" : 100000
          },
          "enable": "parameters[key = \"runelongation\"].model"
        },
        {
          "key": "rundesaturation",
          "label": "Run desaturation pathway analysis",
          "type": "InputSwitch",
          "model": true
        }
      ]
    }
  ],
  "inputs": [
      {
      "key": "input_table",
      "label": "Input table (see Datoma Examples for format)",
      "model": [],
      "shownExtensions": [".csv"]
    }
  ]
}
